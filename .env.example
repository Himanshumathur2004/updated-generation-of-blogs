# ============================================================================
# BLOG GENERATION PIPELINE - ENVIRONMENT CONFIGURATION
# ============================================================================
#
# Copy this file to .env and fill in your actual values
# cp .env.example .env
#
# ============================================================================

# ============================================================================
# MONGODB CONFIGURATION (Required)
# ============================================================================
# Local Development:
#   MONGODB_URI=mongodb://localhost:27017
#   MONGODB_DB=megallm_blog_platform
#
# MongoDB Atlas (Cloud):
#   MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/megallm_blog_platform?retryWrites=true&w=majority

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=megallm_blog_platform

# ============================================================================
# MEGALLM API CONFIGURATION (Required for Blog Generation)
# ============================================================================
# Get your MegaLLM API key from https://beta.megallm.io
MEGALLM_API_KEY=sk-mega-YOUR_API_KEY_HERE
MEGALLM_BASE_URL=https://beta.megallm.io/v1
MEGALLM_MODEL_CONTENT=claude-opus-4-6
MEGALLM_MODEL_FAST=claude-opus-4-6
MEGALLM_MODEL_ANALYSIS=claude-opus-4-6
MODEL=claude-opus-4-6

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================
FLASK_ENV=development
DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production

# ============================================================================
# WF1 CONFIGURATION (Optional - for insight generation)
# ============================================================================
# Leave empty to use MEGALLM_API_KEY
# WF1_MEGALLM_MODEL=claude-opus-4-6

# ============================================================================
# NOTES
# ============================================================================
# 1. MongoDB: Set up a local MongoDB or use MongoDB Atlas
# 2. MegaLLM: Primary API provider for blog generation (claude-opus-4-6)
# 3. Security: Keep .env file out of version control (already in .gitignore)
# 4. For production: Use strong SECRET_KEY and manage credentials securely
